# dod.config — ordered, machine-runnable definition of done for this repo.
# Every line must be a runnable command (dod-check.sh refuses prose).
bash tools/tests/test_version.sh
bash tools/tests/test_upstream.sh
python3 -m unittest discover -s tools/tests -p 'test_*.py'
python3 tools/doctor.py --strict
python3 tools/drift_report.py --check
