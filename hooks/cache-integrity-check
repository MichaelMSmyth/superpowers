#!/usr/bin/env bash
# hooks/cache-integrity-check — SessionStart cache-integrity advisory (F0).
#
# WHAT: governance (MODS.md, drift_report, version bumps) tracks the git CLONE,
# but hooks actually auto-execute from an UNTRACKED cache COPY at
# ${CLAUDE_PLUGIN_ROOT} (~/.claude/plugins/cache/.../<version>/). A write to that
# cache changes what runs every session with no commit, no version bump, no drift
# row. This hook compares the running cache's hooks/ directory (the
# auto-executing surface — round 1 scopes to hooks/ only) against the governed
# clone at its committed HEAD, and, on any mismatch, injects ONE SessionStart
# advisory naming the diverged file(s) and stating that the RUNNING code differs
# from the governed source. On a full match it emits nothing.
#
# DESIGN CHOICE — compare-to-clone (not a self-manifest): the clone is used as
# EXTERNAL truth. A self-manifest shipped inside the cache (a committed
# hooks/.integrity the check recomputes over the cache) is weaker: a tamperer who
# can write the cache can rewrite the manifest in the same breath, so the cache
# would attest to itself. Comparing against the separately-located clone at HEAD
# forces the attacker to also have write access to the governed clone to stay
# hidden.
#
# RESIDUAL GAP (stated plainly, out of scope for round 1): this depends on
# (a) being able to LOCATE the clone from the cache — via the marketplace
# "directory" source recorded in ~/.claude/plugins/known_marketplaces.json (or
# config.json) — and (b) the clone itself being trusted and present. A tamperer
# with write access to the CLONE, or a clone that cannot be located / is absent,
# defeats this check; both fail OPEN (emit nothing) and are accepted risks for
# round 1. Round 1 also scopes to hooks/ only (the auto-executing surface), not
# skills/ or commands/.
#
# ADVISORY ONLY, NON-BLOCKING, FAIL-OPEN: it can only ever ADD a warning, never
# obstruct. Any error, a missing tool (git/python3/sha256sum), or an unlocatable
# clone -> emit nothing and exit 0. It never blocks or fails a session.
#
# TEST SEAM (production path left intact): env overrides CACHE_HOOKS_DIR and
# CLONE_DIR substitute ONLY *where* the two surfaces are found; everything
# downstream (git show HEAD:hooks/<f>, sha256 hashing, advisory shape) is the
# real production logic. Tests point them at a throwaway cache dir and a
# throwaway git clone. Unset in production: CACHE_HOOKS_DIR defaults to
# ${CLAUDE_PLUGIN_ROOT}/hooks and CLONE_DIR is auto-located.

set -uo pipefail

# Locate the governed clone from the marketplace "directory" source. Read-only.
# Prints the clone path on success; nonzero + no output on any failure.
locate_clone() {
  command -v python3 >/dev/null 2>&1 || return 1
  python3 -c 'import json,os,sys
root=os.environ.get("CLAUDE_PLUGIN_ROOT","")
parts=[p for p in root.split(os.sep) if p]
mkt=plug=None
if "cache" in parts:
    i=parts.index("cache")
    if i+1 < len(parts): mkt=parts[i+1]
    if i+2 < len(parts): plug=parts[i+2]
home=os.path.expanduser("~")
cands=[os.path.join(home,".claude","plugins","known_marketplaces.json"),
       os.path.join(home,".claude","plugins","config.json")]
def clone_dir(entry):
    if not isinstance(entry,dict): return None
    src=entry.get("source")
    if isinstance(src,dict) and src.get("source")=="directory":
        p=src.get("path") or entry.get("installLocation")
        if isinstance(p,str) and p: return p
    return None
def ok(p):
    if not p or not os.path.isdir(p): return False
    if not plug: return True
    try:
        pj=json.load(open(os.path.join(p,".claude-plugin","plugin.json"),encoding="utf-8"))
        return pj.get("name")==plug
    except Exception:
        return False
for c in cands:
    try:
        data=json.load(open(c,encoding="utf-8"))
    except Exception:
        continue
    if not isinstance(data,dict): continue
    table=data.get("marketplaces") if isinstance(data.get("marketplaces"),dict) else data
    if not isinstance(table,dict): continue
    if mkt:
        p=clone_dir(table.get(mkt))
        if ok(p): print(p); sys.exit(0)
    for v in table.values():
        p=clone_dir(v)
        if ok(p): print(p); sys.exit(0)
sys.exit(1)
' 2>/dev/null
}

# compare_hooks <cache_hooks_dir> <clone_repo> -> prints one line per diverged
# hooks/ file (empty output == full match). sha256 both sides: governed content
# comes from `git show HEAD:hooks/<f>`, cache content from the file on disk.
compare_hooks() {
  local cache="$1" clone="$2"
  local governed_list _mode _type _sha _path name gh ch f base

  # Names of the blobs directly under hooks/ at HEAD (trees like examples/ are
  # type!=blob and skipped). Non-recursive: round 1 scopes to top-level hooks/.
  governed_list=$(git -C "$clone" ls-tree HEAD hooks/ 2>/dev/null | while read -r _mode _type _sha _path; do
    [ "$_type" = blob ] || continue
    printf '%s\n' "${_path#hooks/}"
  done)

  # Empty governed list => cannot establish governed truth (wrong/broken clone).
  # Fail open: emit nothing rather than blast a false advisory on every file.
  [ -n "$governed_list" ] || return 0

  # Pass 1: every governed hook file — compare against the cache.
  while IFS= read -r name; do
    [ -n "$name" ] || continue
    if [ ! -f "$cache/$name" ]; then
      printf '%s (present in governed source, missing from running cache)\n' "$name"
      continue
    fi
    gh=$(git -C "$clone" show "HEAD:hooks/$name" 2>/dev/null | sha256sum 2>/dev/null | awk '{print $1}')
    ch=$(sha256sum < "$cache/$name" 2>/dev/null | awk '{print $1}')
    # Only flag when we have both hashes and they differ (a missing hash is a
    # transient read error, not evidence of tampering -> fail open, stay silent).
    if [ -n "$gh" ] && [ -n "$ch" ] && [ "$gh" != "$ch" ]; then
      printf '%s (running cache differs from governed source)\n' "$name"
    fi
  done <<< "$governed_list"

  # Pass 2: cache files with no governed counterpart (injected into the cache).
  for f in "$cache"/*; do
    [ -f "$f" ] || continue
    base=$(basename "$f")
    if ! printf '%s\n' "$governed_list" | grep -qxF -- "$base"; then
      printf '%s (present in running cache, absent from governed source)\n' "$base"
    fi
  done
}

# emit_advisory <diverged-lines> -> prints the SessionStart advisory as valid
# JSON (json.dumps guarantees escaping). No python3 -> emit nothing (fail open).
emit_advisory() {
  local diverged="$1"
  command -v python3 >/dev/null 2>&1 || return 0
  printf '%s' "$diverged" | python3 -c 'import json,sys
files=[l.strip() for l in sys.stdin.read().splitlines() if l.strip()]
if not files:
    sys.exit(0)
msg=("CACHE-INTEGRITY (advisory, non-blocking): the RUNNING plugin code under "
     "CLAUDE_PLUGIN_ROOT differs from the governed source clone at HEAD. "
     "Diverged hooks/ file(s):\n"
     + "\n".join("  - "+f for f in files) + "\n"
     "Canonical form: the executing cache must byte-match the committed clone; "
     "reconcile by re-shipping from the clone (tools/ship.sh) or reverting the "
     "unauthorized cache write, then re-verify.\n"
     "Averted: unreviewed code auto-executing every session with no commit, "
     "version bump, or MODS.md drift row.")
print(json.dumps({"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":msg}}))
' 2>/dev/null || return 0
}

main() {
  local cache_hooks clone diverged

  cache_hooks="${CACHE_HOOKS_DIR:-${CLAUDE_PLUGIN_ROOT:-}/hooks}"
  [ -d "$cache_hooks" ] || return 0

  clone="${CLONE_DIR:-}"
  if [ -z "$clone" ]; then
    clone=$(locate_clone) || return 0
  fi
  [ -n "$clone" ] || return 0

  command -v git >/dev/null 2>&1 || return 0
  command -v sha256sum >/dev/null 2>&1 || return 0
  git -C "$clone" rev-parse --verify HEAD >/dev/null 2>&1 || return 0

  diverged=$(compare_hooks "$cache_hooks" "$clone")
  [ -n "$diverged" ] || return 0

  emit_advisory "$diverged"
  return 0
}

# Fail-open wrapper: whatever happens inside, exit 0. main only ever prints an
# advisory (or nothing) to stdout, so stdout is always empty or one valid JSON
# object — it can never emit garbage that would break context injection.
main || true
exit 0
